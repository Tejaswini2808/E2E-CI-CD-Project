[Unit]
Description=flask app
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Jenkins-Project/
Environment="PATH=/home/ubuntu/Jenkins-Project/venv/bin"
ExecStart=/home/ubuntu/Jenkins-Project/venv/bin/python3 /home/ubuntu/Jenkins-Project/app.py

[Install]
WantedBy=multi-user.target
