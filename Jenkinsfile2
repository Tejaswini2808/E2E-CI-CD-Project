pipeline {
    agent any

    stages {
        stage('Setup') {
            steps {
                sh '''
                    python3 -m venv venv
                    ./venv/bin/python -m pip install --upgrade pip
                    ./venv/bin/python -m pip install -r requirements.txt
                '''
            }
        }
        stage('Test') {
            steps {
                sh '''
                    ./venv/bin/python -m pytest
                '''
            }
        }
       stage('Deployment') {
           steps {
               echo "Running Deployment"
           }    
       }
    }
}
