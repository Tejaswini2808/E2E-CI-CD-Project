pipeline {
    agent any

    stages {
        stage('SCM checkout') {
          steps{
          git url:'https://github.com/Tejaswini2808/Jenkins-Project.git', branch: 'main'
        }
        }
        stage('Setup') {
            steps {
             
                sh "pip3 install -r requirements.txt"
            
            }
        }
        stage('Test') {
            steps {
                sh "pytest"
                
            }
        }    
        stage('Deployment') {
            input {
                message "Do you want to proceed further?"
                ok "Yes"
            }
            steps {
                echo "Running Deployment"
                
            }
        } 
        
            
    }
}
